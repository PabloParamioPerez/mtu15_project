# Copy this file to the repo root as `.env` and fill in your own credentials.
#   cp replication/.env.example .env
#
# OMIE downloads are PUBLIC and need no credentials.
# ESIOS and ENTSO-E downloads require free API access (register on each platform).
# These are only needed for STAGE 0 (data download); if you already have the
# processed parquet, the data stages are skipped and no credentials are used.

# ENTSO-E Transparency Platform API token (https://transparency.entsoe.eu/ -> account -> "Web API")
ENTSOE_TOKEN=

# ENTSO-E Transparency Platform web login (used by a few SFTP/bulk endpoints)
TP_USERNAME=
TP_PASSWORD=

# ESIOS (REE) API token (https://www.esios.ree.es/ -> personal token)
ESIOS_TOKEN=
