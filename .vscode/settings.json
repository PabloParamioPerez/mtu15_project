{
  // R extension (REditorSupport.r). Extension recommendations live in
  // .vscode/extensions.json.
  //
  // radian is a modern R REPL (installed via `uv tool install radian`).
  // If you prefer plain R, replace the path below with the output of
  // `which R` and set r.bracketedPaste to false.
  "r.rterm.mac": "/Users/pabloparamio/.local/bin/radian",
  "r.bracketedPaste": true,

  // httpgd is the in-editor plot device. Installed at user level.
  "r.plot.useHttpgd": true,

  // Session watcher: RStudio-equivalent environment pane, plot history,
  // help panel in VS Code's R sidebar.
  "r.sessionWatcher": true,

  // Linter / LSP diagnostics via the `languageserver` R package.
  "r.lsp.diagnostics": true,
  "r.lsp.debug": false,

  // Python interpreter — the uv-managed venv.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // File associations for R + Stata + Quarto.
  "files.associations": {
    "*.R": "r",
    "*.r": "r",
    "*.Rmd": "rmd",
    "*.qmd": "quarto",
    "*.do": "stata",
    "*.ado": "stata"
  },

  // Hide noisy generated folders from the explorer.
  "files.exclude": {
    "**/.DS_Store": true,
    "**/renv/library": true,
    "**/renv/staging": true,
    "**/renv/sandbox": true,
    "**/__pycache__": true
  },

  // Search should ignore those too.
  "search.exclude": {
    "**/renv/library": true,
    "**/renv/staging": true,
    "**/renv/sandbox": true
  }
}
