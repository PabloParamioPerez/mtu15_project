{
  // ── R extension (REditorSupport.r) ─────────────────────────────────────────
  //
  // radian is a modern R REPL installed via `uv tool install radian`.
  // If you prefer plain R, replace the path with the output of `which R`
  // and set r.bracketedPaste to false.
  "r.rterm.mac": "/Users/pabloparamio/.local/bin/radian",
  "r.bracketedPaste": true,
  "r.plot.useHttpgd": true,
  "r.sessionWatcher": true,
  "r.lsp.diagnostics": true,
  "r.lsp.debug": false,

  // ── Python ────────────────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // ── File associations (R / Stata / Quarto) ────────────────────────────────
  "files.associations": {
    "*.R": "r",
    "*.r": "r",
    "*.Rmd": "rmd",
    "*.qmd": "quarto",
    "*.do": "stata",
    "*.ado": "stata"
  },

  // ── Hide ONLY inert regenerated content ───────────────────────────────────
  //
  // Principle: only hide things you would NEVER edit or need to know about.
  // Caches that regenerate themselves and vendored content are safe to hide.
  // Config files, dotfiles, and anything "load-bearing" stays visible so
  // future-you doesn't forget they exist.
  "files.exclude": {
    "**/.DS_Store": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.ipynb_checkpoints": true
  },

  // ── Group related files under a visible expandable parent ─────────────────
  //
  // Nested files REMAIN VISIBLE — click the ▸ on the parent to see them.
  // This is the safer pattern than files.exclude because you can't forget
  // about a file you can still see in the tree.
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "pyproject.toml": "uv.lock, .python-version, .ruff.toml, ruff.toml, mypy.ini, .flake8, tox.ini",
    "renv.lock": ".Rprofile, renv",
    "README.md": "CLAUDE.md, LICENSE*, CHANGELOG*, CONTRIBUTING*, CODE_OF_CONDUCT*",
    ".gitignore": ".gitattributes, .editorconfig, .env.example",
    "*.ipynb": "${capture}.py"
  },

  // ── Search: skip large vendored/cached trees for speed ────────────────────
  //
  // This affects Ctrl+Shift+F search only, not file visibility. Excluding
  // .venv and renv/library from search makes Find-in-Files fast; you can
  // still browse these folders in the Explorer.
  "search.exclude": {
    "**/.venv": true,
    "**/renv/library": true,
    "**/renv/staging": true,
    "**/renv/sandbox": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.ipynb_checkpoints": true
  }
}
