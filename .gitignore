# Secrets
.env

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/.ropeproject

# Data
data/**
!data/raw/
!data/interim/
!data/processed/
!data/external/
!data/metadata/
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/external/omie_reference/
!data/external/omie_reference/*.csv
!data/external/omie_reference/README.md
!data/metadata/.gitkeep
data/metadata/*.csv
# ESIOS folder documentation (not the bulk data)
!data/raw/esios/
!data/raw/esios/**/
!data/raw/esios/**/README.md
!data/raw/esios/**/.gitkeep

# Docs
/docs

# Outputs
*.log

# Local backups
attic/

# Exploratory analysis — track notebooks, ignore heavy outputs
explore/**/.ipynb_checkpoints/
explore/.tmp/

# R (renv) — commit renv.lock + activate.R, ignore per-machine library
renv/library/
renv/staging/
renv/sandbox/
renv/python/
.Rhistory
.RData
.Ruserdata
*.Rproj.user/

# LaTeX build artefacts
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.out
*.toc
